NODE_ENV=development

# Server
PORT=5001

# Email
RESEND_API_KEY=
MAIL_FROM=
MAIL_TO_OVERRIDE=

# ImageKit
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=

# Optional / existing app settings
LOG_NO_ORIGIN=true
UNIT_TURNAROUND_MINUTES=0

# Google Sign-In (optional)
# Isi dengan OAuth Client ID (Web). Bisa beberapa, pisahkan dengan koma.
GOOGLE_CLIENT_ID=

# Telegram notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ADMIN_URL=http://localhost:5173/admin

# Optional: Telegram Forum Topics (message_thread_id) for routing notifications
# LOG SERVER
TELEGRAM_TOPIC_LOG=
# TRANSAKSI / BOOKING (motor/mobil)
TELEGRAM_TOPIC_BOOKING=
# KONFIRMASI (bukti transfer masuk + payment confirmed)
TELEGRAM_TOPIC_PAYMENT=
# Optional split:
# BUKTI TRANSFER (upload proof)
TELEGRAM_TOPIC_PAYMENT_PROOF=
# KONFIRMASI PAYMENT (admin matched)
TELEGRAM_TOPIC_PAYMENT_CONFIRMED=
# SMART LOKER
TELEGRAM_TOPIC_LOCKER=
# KYC
TELEGRAM_TOPIC_KYC=
# GOOGLE REVIEW
TELEGRAM_TOPIC_REVIEW=
