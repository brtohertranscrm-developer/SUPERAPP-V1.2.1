# Optional.
# Kosongkan jika frontend & backend dipublish di domain yang sama dan kamu punya reverse proxy untuk `/api`.
# Contoh: VITE_API_URL=https://superapp.example.com
VITE_API_URL=

# Optional (DEV saja).
# Default-nya otomatis `http://localhost:5001` untuk proxy `/api` ketika `npm run dev`.
# Kalau backend kamu jalan di host/port lain, set ini tanpa perlu edit `vite.config.js`.
VITE_DEV_PROXY_TARGET=http://localhost:5001

